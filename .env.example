# ─── Database ───────────────────────────────────────────────────────────────────
# Login user that INHERITS from felixos_app_role (NOLOGIN group role, NOBYPASSRLS).
DATABASE_URL=postgresql://felixos_app:changeme@postgres:5432/felixos

# Login user that INHERITS from felixos_privileged_role (NOLOGIN group role, BYPASSRLS).
# Used by migrations, provisioning, seed, and recovery CLI.
DATABASE_PRIVILEGED_URL=postgresql://felixos_privileged:changeme@postgres:5432/felixos

# Postgres superuser — used only by the migrate init container.
# Never used by app services at runtime.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=felixos

# Explicit credentials for the two login users the migrate container provisions.
# Must match the username/password encoded in DATABASE_URL and DATABASE_PRIVILEGED_URL above.
# Kept separate so the migrate script never needs to parse a connection string.
APP_DB_USER=felixos_app
APP_DB_PASS=changeme
PRIV_DB_USER=felixos_privileged
PRIV_DB_PASS=changeme

# ─── Auth ────────────────────────────────────────────────────────────────────────
# High-entropy session secret for signing session tokens (min 32 bytes)
SESSION_SECRET=replace-with-a-high-entropy-random-string-at-least-32-chars

# AES-GCM key for encrypting TOTP secrets at rest — 32-byte hex (64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit a real key — keep outside VCS (e.g. in a secrets manager)
TOTP_SECRET_ENCRYPTION_KEY=replace-with-64-hex-chars-generated-by-the-command-above

# ─── Knowledge Core LLM ─────────────────────────────────────────────────────────
# OpenAI-compatible chat + embeddings provider used by Phase 2 distillation.
LLM_API_KEY=replace-with-provider-api-key
LLM_BASE_URL=
DISTILLATION_MODEL=replace-with-chat-model
EMBEDDING_MODEL=replace-with-1024-dim-embedding-model

# ─── App ─────────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Port the Fastify API listens on inside the container
API_PORT=3001

# Internal base URL used by the Next.js web container to reach the API.
# next.config.ts reads this at build time to bake rewrite destinations;
# pass it as a build arg (docker-compose handles this automatically).
FELIXOS_API_ORIGIN=http://api:3001

# Public base URL (used for same-origin Cloudflare proxy — set to your domain)
PUBLIC_URL=https://app.example.com
